CREATE TABLE Exhibit (
    id INTEGER NOT NULL PRIMARY KEY AUTOINCREMENT,
    name TEXT NOT NULL,
    createdAt INTEGER NOT NULL
);

insert:
INSERT INTO Exhibit(name, createdAt)
VALUES (?, ?);

lastInsertRowId:
SELECT last_insert_rowid();

selectAll:
SELECT *
FROM Exhibit
ORDER BY createdAt DESC;

selectById:
SELECT *
FROM Exhibit
WHERE id = ?;

rename:
UPDATE Exhibit
SET name = ?
WHERE id = ?;

deleteById:
DELETE FROM Exhibit
WHERE id = ?;
